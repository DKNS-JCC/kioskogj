# Configuración del backend. Copiar a `.env` y ajustar.
# Las claves se leen con pydantic-settings desde app/config.py (Fase 2).

# Ruta absoluta o relativa al fichero SQLite.
KIOSKO_DB_PATH=./database.db

# Origen permitido para CORS desde el frontend (Caddy sirve estáticos).
# En producción esto será el dominio de la PWA, p.ej. https://kiosko.local.
KIOSKO_CORS_ORIGINS=http://localhost:5173

# Nivel de log: DEBUG / INFO / WARNING / ERROR.
KIOSKO_LOG_LEVEL=INFO

# Zona horaria del campamento (frontera de "hoy" para cota diaria).
KIOSKO_TZ=Europe/Madrid

# PIN admin sembrado al primer arranque si la tabla configuracion está vacía.
# Cámbialo desde la PWA cuanto antes.
KIOSKO_PIN_ADMIN_DEFAULT=0000

# Cota diaria por defecto en €.
KIOSKO_COTA_DIARIA_DEFAULT=2.50
